# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_QURAN_COLLECTION=quran_verses
CHROMA_HADITH_COLLECTION=sahih_bukhari

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Retrieval Settings
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# App Settings
APP_NAME=HIKMAH AI
APP_VERSION=1.0.0
DEBUG=false
